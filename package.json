{
  "name": "technova-o2c",
  "version": "1.0.0",
  "description": "TechNova Solutions Order-to-Cash process on SAP BTP using SAP CAP",
  "repository": {
    "type": "git",
    "url": "https://github.com/Codinggenie2004/technova-o2c.git"
  },
  "license": "MIT",
  "private": true,
  "dependencies": {
    "@cap-js/sqlite": "^2.2.0",
    "@sap/cds": "^9",
    "@sap/cds-dk": "^9",
    "@sap/xssec": "^4.13.0",
    "express": "^4",
    "passport": "^0.7.0"
  },
  "scripts": {
    "start": "cds-serve",
    "dev": "cds watch",
    "build": "cds build --production",
    "deploy:sqlite": "cds deploy --to sqlite",
    "test": "echo \"No tests yet\""
  },
  "cds": {
    "requires": {
      "db": {
        "kind": "sqlite",
        "[production]": {
          "kind": "sqlite",
          "deploy": true,
          "credentials": {
            "url": ":memory:"
          }
        }
      },
      "auth": {
        "kind": "mocked",
        "[production]": {
          "kind": "mocked"
        }
      }
    },
    "features": {
      "fetch_csrf": true
    },
    "server": {
      "port": 4004
    }
  }
}
